{% extends "layout.html.j2" %}

{% block title -%}
	<title>Ngeprint.Kuy</title>
{%- endblock %}

{% block script_src -%}
	<script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.1.2/socket.io.js" charset="utf-8"></script>
{%- endblock %}

{% block content -%}
	<div class="ui stackable three column middle aligned grid" style="height: 100vh">
		<div class="column"></div>
		<div class="column">
			<h1 class="ui center aligned header">Web Printing Service</h1>
			<div class="ui top attached segment">
				<div class="ui fluid left icon transparent input">
					<input type="text" value="{{ job["client_file"] }}" readonly>
					<i class="pdf file icon"></i>
				</div>
				<table class="ui unstackable compact three column small celled table">
					<thead>
						<tr>
							<th>&nbsp;</th>
							<th>Jumlah</th>
							<th>Total</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td>Grayscale</td>
							<td>12</td>
							<td>12000</td>
						</tr>
						<tr>
							<td>Color</td>
							<td>10</td>
							<td>20000</td>
						</tr>
						<tr>
							<td>Blank</td>
							<td>2</td>
							<td>1000</td>
						</tr>
					</tbody>
					<tfoot>
						<tr>
							<th>&nbsp;</th>
							<th><strong>24</strong></th>
							<th><strong>33000</strong></th>
						</tr>
					</tfoot>
				</table>
				<button id="btn-agree" class="ui small primary labeled icon button"><i class="check icon"></i>Setuju</button>
				<button id="btn-cancel" class="ui small orange labeled icon button"><i class="times icon"></i>Batal</button>
			</div>
		</div>
		<div class="column"></div>
	</div>
{%- endblock %}

{% block script %}
	<script type="text/javascript" id="params" data-id="{{ job["id"] }}"></script>
	<script type="text/javascript">_.q().cost.init();</script>
{% endblock %}
