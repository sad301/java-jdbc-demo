{% extends "layout.html.j2" %}

{% block title -%}
	<title>Ngeprint.Kuy</title>
{%- endblock %}

{% block script_src -%}
	<script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.1.2/socket.io.js" charset="utf-8"></script>
{%- endblock %}

{% block content -%}
	<div class="ui stackable three column middle aligned grid" style="height: 100vh">
		<div class="column"></div>
		<div class="column">
			<h1 class="ui center aligned header">Web Printing Service<div class="sub header">Versi 1.0.0</div></h1>
			<div class="ui loading segment">
				<div class="ui fluid left icon transparent input">
					<input type="text" id="client_file" readonly>
					<i class="pdf file icon"></i>
				</div>
				<table class="ui unstackable compact three column small celled table">
					<thead>
						<tr>
							<th>&nbsp;</th>
							<th class="right aligned">Jumlah</th>
							<th class="right aligned">Total</th>
						</tr>
					</thead>
					<tbody>
						<tr id="grayscale">
							<td>Grayscale</td>
							<td class="right aligned">0</td>
							<td class="right aligned">0</td>
						</tr>
						<tr id="color">
							<td>Color</td>
							<td class="right aligned">0</td>
							<td class="right aligned">0</td>
						</tr>
						<tr id="blank">
							<td>Blank</td>
							<td class="right aligned">0</td>
							<td class="right aligned">0</td>
						</tr>
					</tbody>
					<tfoot>
						<tr id="total">
							<th>&nbsp;</th>
							<th class="right aligned">0</th>
							<th class="right aligned">0</th>
						</tr>
					</tfoot>
				</table>
				<button id="btn-confirm" class="ui small primary labeled icon button"><i class="check icon"></i>Konfirmasi</button>
				<button id="btn-cancel" class="ui small orange labeled icon button"><i class="times icon"></i>Batal</button>
			</div>
		</div>
		<div class="column"></div>
	</div>
	<!-- templates -->
	<template id="warning-message-template">
		<div class="ui icon warning message">
			<i class="exclamation triangle icon"></i>
			<div class="content">
				<div class="header">Pemberitahuan</div>
				<p>Konfirmasi melalui SMS di non-aktifkan karena jumlah halaman melebihi batas maksimum. Harap menghubungi operator untuk mendapatkan kode konfirmasi</p>
			</div>
		</div>
	</template>
	<template id="button-agree-template">
		<button class="ui small primary labeled icon button"><i class="check icon"></i>Setuju</button>
	</template>
	<template id="button-cancel-template">
		<button class="ui small orange labeled icon button"><i class="times icon"></i>Batal</button>
	</template>
{%- endblock %}

{% block script %}
	<script type="text/javascript" id="params" data-id="{{ id }}"></script>
	<script type="text/javascript">_.q().cost.init();</script>
{% endblock %}
