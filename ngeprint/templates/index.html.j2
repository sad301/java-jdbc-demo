{% extends "layout.html.j2" %}

{% block title %}
	<title>Ngeprint.Kuy</title>
{% endblock %}

{% block content %}
	<div class="ui stackable three column middle aligned grid" style="height: 100vh">
		<div class="column"></div>
		<div class="column">
			<div class="ui top attached icon info message">
				<i class="info circle icon"></i>
				<div class="content">
					<div class="header">Selamat Datang</div>
					<p>Masukkan informasi dibawah</p>
				</div>
			</div>
			<div class="ui bottom attached padded small form segment">
				<div class="field">
					<div class="ui left icon input">
						<input type="text" name="" value="" placeholder="Nama">
						<i class="user icon"></i>
					</div>
				</div>
				<div class="field">
					<div class="ui left icon input">
						<input type="text" name="" value="" placeholder="Handphone">
						<i class="mobile alternate icon"></i>
					</div>
				</div>
				<div class="field">
					<div class="ui left icon right action input">
						<i class="pdf file icon"></i>
						<input id="txt-dokumen" type="text" placeholder="Dokumen">
						<input type="file" name="" value="" style="display: none">
						<button id="btn-select-file" class="ui icon button"><i class="folder open icon"></i></button>
					</div>
				</div>
				<button class="ui small primary labeled icon button"><i class="send icon"></i>Kirim</button>
			</div>
		</div>
		<div class="column"></div>
	</div>
{% endblock %}

{% block script %}
	<script type="text/javascript">_.q().index();</script>
{% endblock %}
