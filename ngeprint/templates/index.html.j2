{% extends "layout.html.j2" %}

{% block title %}
	<title>Ngeprint.Kuy</title>
{% endblock %}

{% block content %}
	<div class="ui stackable three column middle aligned grid" style="height: 100vh">
		<div class="column"></div>
		<div class="column">
			<h2 class="ui center aligned header">Web Printing Service</h2>
			<div class="ui top attached icon info message">
				<i class="info circle icon"></i>
				<div class="content">
					<div class="header">Informasi</div>
					<p>If you're new here, please read <a href="#">this</a> first</p>
				</div>
			</div>
			<form class="ui bottom attached padded small form segment" method="post" enctype="multipart/form-data">
				<div class="field">
					<div class="ui left icon input">
						<input type="text" name="nama" placeholder="Nama">
						<i class="user icon"></i>
					</div>
				</div>
				<div class="field">
					<div class="ui left icon input">
						<input type="text" name="handphone" placeholder="Handphone">
						<i class="mobile alternate icon"></i>
					</div>
				</div>
				<div class="field">
					<div class="ui left icon right action input">
						<i class="pdf file icon"></i>
						<input id="txt-dokumen" type="text" placeholder="Dokumen" readonly>
						<input type="file" name="dokumen" accept="application/pdf" style="display: none">
						<button id="btn-select-file" class="ui icon button"><i class="folder open icon"></i></button>
					</div>
				</div>
				<input type="hidden" name="id" value="{{ id }}">
				<button id="btn-send" class="ui small primary labeled icon button"><i class="send icon"></i>Kirim</button>
			</form>
		</div>
		<div class="column"></div>
	</div>
{% endblock %}

{% block script %}
	<script type="text/javascript">_.q().index.init();</script>
{% endblock %}
