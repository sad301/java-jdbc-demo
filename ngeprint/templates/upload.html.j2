{% extends "layout.html.j2" %}

{% block title %}
	<title>Ngeprint.Kuy</title>
{% endblock %}

{% block content %}
	<div class="ui stackable three column middle aligned grid" style="height: 100vh">
		<div class="column"></div>
		<div class="column">
			<h1 class="ui center aligned header">Web Printing Service</h1>
			<div class="ui small padded form segment">
				<div class="field">
					<div class="ui left icon input">
						<input type="text" value="{{ job["client_file"] }}" readonly>
						<i class="pdf file icon"></i>
					</div>
				</div>
				<div class="ui buttons">
					<button type="button" name="button" class="ui primary button">Confirm</button>
					<button type="button" name="button" class="ui red button">Cancel</button>
				</div>
			</div>
		</div>
		<div class="column"></div>
	</div>
{% endblock %}

{% block script %}
	<script type="text/javascript">_.q().upload.init();</script>
{% endblock %}
