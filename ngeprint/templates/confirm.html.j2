{% extends "layout.html.j2" %}

{% block title %}
  <title>Konfirmasi</title>
{% endblock %}

{% macro info_message() %}
  <div class="ui top attached icon message">
    <i class="info circle icon"></i>
    <div class="content">
      <div class="header">Informasi</div>
      <p>Ketikkan kode konfirmasi yang telah dikirimkan ke nomor handphone anda</p>
    </div>
  </div>
{% endmacro %}

{% macro warning_message(messages) %}
  <div class="ui top attached icon message">
    <i class="exclamation triangle icon"></i>
    <div class="content">
      <div class="header">Konfirmasi SMS di Non-Aktifkan</div>
      <ul class="list">
        {% for message in messages %}
          <li>{{ message }}</li>
        {% endfor %}
      </ul>
    </div>
  </div>
{% endmacro %}

{% block content %}
  <div class="ui stackable three column middle aligned grid" style="height: 100vh">
    <div class="column"></div>
    <div class="column">
      <h1 class="ui center aligned header">Web Printing Service<div class="sub header">Versi 1.0.0</div></h1>
      {% if messages|length > 0 %}
        {{ warning_message(messages) }}
      {% else %}
        {{ info_message() }}
      {% endif %}
      <div class="ui bottom attached small padded form segment">
        <div class="field">
          <label>Kode Konfirmasi :</label>
          <div class="ui input">
            <input type="text" class="twelve digit">
          </div>
        </div>
        <button class="ui tiny primary labeled icon disabled button"><i class="send icon"></i>Kirim</button>
      </div>
    </div>
    <div class="column"></div>
  </div>
{% endblock %}

{% block script %}
  <script type="text/javascript" id="params" data-id="{{ job.id }}"></script>
  <script type="text/javascript">_.q().confirm.init();</script>
{% endblock %}
